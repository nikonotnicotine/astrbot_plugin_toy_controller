{
  "toy_api_url": {
    "description": "本地控制脚本的API地址",
    "type": "string",
    "default": "http://127.0.0.1:8080/command"
  },
  "stop_cmd": {
    "description": "停止指令",
    "type": "string",
    "default": "55 04 00 00 00 00 AA"
  },
  "speed_cmd_template": {
