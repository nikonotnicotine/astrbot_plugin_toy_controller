    "type": "string",
    "default": "55 04 00 00 01 {intensity} AA"
  },
  "vibrate_cmd_template": {
    "description": "花样指令模板 (含 {mode} 和 {level} 变量)",
    "type": "string",
    "default": "55 03 00 00 {mode} {level} AA"
  }
}
